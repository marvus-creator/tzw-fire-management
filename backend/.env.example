# Copy to .env locally, and set these as environment variables on Render.
PORT=5000

# MongoDB Atlas connection string (Database tab > Connect > Drivers)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/tzw_fire_db

# Use a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d
NODE_ENV=production

# The deployed frontend URL (Vercel) — used for CORS and password-reset links
FRONTEND_URL=https://your-frontend.vercel.app

# The deployed backend URL (Render) — shown in Swagger docs
API_URL=https://your-backend.onrender.com

# SMTP email (leave blank to log emails to the server console instead)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="TZW Fire Management <no-reply@tzw.com>"
